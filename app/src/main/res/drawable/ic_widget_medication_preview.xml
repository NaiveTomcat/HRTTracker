<?xml version="1.0" encoding="utf-8"?>
<!-- Pill icon for previewLayout: safe for RemoteViews (shape drawables work on all API levels) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pill outline -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#65558F" />
        </shape>
    </item>
    <!-- Horizontal dividing line -->
    <item
        android:top="7dp"
        android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#65558F" />
        </shape>
    </item>
</layer-list>
